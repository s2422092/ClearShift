# ── Supabase 接続情報（ここに値を入れるだけで接続できます）─────────────────────
# Supabase ダッシュボード → Project Settings → Database から取得

# 方法A: 接続URLをそのまま貼る（推奨）
# Vercel/本番用: Transaction Pooler の URL を使うこと（ポート 6543）
# ローカル開発用: Direct Connection の URL を使うこと（ポート 5432）
DATABASE_URL=postgresql://postgres.vrwordtjjfbbtpbijjth:lsalgieapyugosyu123@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# 方法B: 個別変数で指定する（DATABASE_URL が空のとき使用される）
DB_HOST=aws-1-ap-northeast-1.pooler.supabase.com
DB_NAME=postgres
DB_USER=postgres.vrwordtjjfbbtpbijjth
DB_PASSWORD=lsalgieapyugosyu123
